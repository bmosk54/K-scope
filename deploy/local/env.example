# Copy this to .env.local at the repo root (gitignored) and fill in your key:
#   cp deploy/local/env.example .env.local
# bin/kscope sources it automatically before starting the backend.

# --- LLM for the "K-Pro answer" + "optimize prompt" buttons ----------------------
# Everything else (certify / steer / ablate / probe / specificity) is pure local
# torch+numpy and needs NONE of this. This is ONLY for the two buttons that call an
# LLM to (a) draft a plausible K-Pro answer from the tile, and (b) rewrite a prompt.
#
# IMPORTANT: a ChatGPT Plus/Pro *subscription* (chat.openai.com) does NOT include API
# access. You need a separate API key from https://platform.openai.com/api-keys, and
# separate billing set up at https://platform.openai.com/account/billing (pay-per-
# token; a few cents will run this whole demo many times over).
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.6-terra

# --- backend port ------------------------------------------------------------------
PORT=4173

# --- set by deploy/local/setup_cloudflare_tunnel.sh — informational only, bin/kscope
# reads the hostname straight out of ~/.cloudflared/kscope-config.yml, not from here.
# CLOUDFLARE_HOSTNAME=kscope.yourdomain.com
